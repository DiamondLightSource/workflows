    },
    "frontend/dashboard": {
      "release-type": "node",
      "package-name": "frontend/dashboard"
    },
    "frontend/relay-workflows-lib": {
      "release-type": "node",
      "package-name": "frontend/relay-workflows-lib"
    },
    "frontend/workflows-lib": {
      "release-type": "node",
      "package-name": "frontend/workflows-lib"
    }
  }
}

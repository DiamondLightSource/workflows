      "package-name": "sessionspaces"
    },
    "charts/apps": {
      "release-type": "helm",
      "package-name": "helm/apps"
    },
    "charts/argocd": {
      "release-type": "helm",
      "package-name": "helm/argocd"
    },
    "charts/dashboard": {
      "release-type": "helm",
      "package-name": "helm/frontend"
    },
    "charts/events": {
      "release-type": "helm",
      "package-name": "helm/frontend"
    },
    "charts/graph-proxy": {
      "release-type": "helm",
      "package-name": "helm/graph-proxy"
    },
    "charts/groups": {
      "release-type": "helm",
      "package-name": "helm/groups"
    },
    "charts/sessionspaces": {
      "release-type": "helm",
      "package-name": "helm/sessionspaces"
    },
    "charts/verflixt": {
      "release-type": "helm",
      "package-name": "helm/verflixt"
    },
    "charts/workflows": {
      "release-type": "helm",

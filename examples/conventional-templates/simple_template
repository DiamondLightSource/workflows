apiVersion: argoproj.io/v1alpha1
kind: Workflow
metadata:
  name: boilerplate-example
  labels:
    workflows.diamond.ac.uk/science-group-examples: "true"
  annotations:
    workflows.argoproj.io/title: very-simple-workflow
    workflows.argoproj.io/description: |
        This is an example demo-ing a simple template

spec:
  entrypoint: workflow-entry
  volumeClaimTemplates:
  - metadata:
      name: tmpdir
    spec:
      accessModes: [ "ReadWriteOnce" ]
      resources:
        requests:
          storage: 1Gi
      storageClassName: local-path

  templates:
  - name: step-one
    script:
      image: busybox
      command: [bash]
      source: |
        echo "Hello Simple world"

  - name: workflow-entry
    dag:
      tasks:
      - name: step-one
        template: step-one